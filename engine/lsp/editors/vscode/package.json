{
  "name": "lemma-language",
  "displayName": "Lemma Language",
  "description": "Language support for Lemma: syntax highlighting, inline diagnostics, and clickable Registry references",
  "version": "0.8.12",
  "publisher": "lemma",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lemma/lemma"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:lemma"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lemma",
        "aliases": [
          "Lemma",
          "lemma"
        ],
        "extensions": [
          ".lemma"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lemma",
        "scopeName": "source.lemma",
        "path": "./syntaxes/lemma.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Lemma",
      "properties": {
        "lemma.lspServerPath": {
          "type": "string",
          "default": "lsp",
          "description": "Path to the lsp binary. If not absolute, the binary is looked up on $PATH."
        }
      }
    },
    "configurationDefaults": {
      "[lemma]": {
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "file",
        "editor.defaultFormatter": "lemma.lemma-language"
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "precommit": "npm ci && npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
