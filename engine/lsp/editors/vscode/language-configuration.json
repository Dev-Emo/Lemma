{
  "comments": {
    "blockComment": ["\"\"\"", "\"\"\""]
  },
  "brackets": [
    ["(", ")"]
  ],
  "autoClosingPairs": [
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "/",
      "close": "/"
    }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["\"", "\""],
    ["/", "/"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(rule).*$",
    "decreaseIndentPattern": "^\\s*(then|unless).*$"
  },
  "folding": {
    "markers": {
      "start": "^\\s*\"\"\"",
      "end": "^\\s*\"\"\""
    }
  }
}























