{
  "name": "lemma-language",
  "displayName": "Lemma Language",
  "description": "Syntax highlighting for Lemma programming language",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lemma",
        "aliases": [
          "Lemma",
          "lemma"
        ],
        "extensions": [
          ".lemma"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lemma",
        "scopeName": "source.lemma",
        "path": "./lemma.tmLanguage.json"
      }
    ]
  }
}




