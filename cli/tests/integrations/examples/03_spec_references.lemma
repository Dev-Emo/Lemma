spec base_employee
"""
Base Employee Spec

Defines basic employee facts that can be referenced and extended.
"""

fact department:          "Engineering"
fact employment_duration: 0 years
fact is_full_time:        true
fact name:                "John Doe"
fact monthly_salary:      [number -> minimum 0 -> default 5000]

rule annual_salary:
  monthly_salary * 12

rule is_eligible_for_bonus:
  false
  unless employment_duration >= 1 years then true


spec specific_employee
"""
Specific Employee Spec

References the base employee spec and binds specific facts.
Demonstrates spec composition, fact binding, and rule references.
"""

fact employee:                     spec base_employee
fact employee.employment_duration: 3 years
fact employee.monthly_salary:      7500
fact employee.name:                "Alice Smith"

rule salary_with_bonus:
  employee.annual_salary
  unless employee.is_eligible_for_bonus
    then employee.annual_salary * 1.1

rule employee_summary:
  employee.name


spec contractor
"""
Contractor Spec

Shows a different employment model using spec references.
"""

type money: scale
  -> unit eur 1.00

fact hours_worked: 120 hours
fact hourly_rate:  [money -> minimum 0 -> default 85 eur]

fact person:              spec base_employee
fact person.is_full_time: false

rule total_payment:
  hourly_rate * hours_worked

rule annual_hours:
  hours_worked * 12

rule benefits_eligible:
  false
  unless annual_hours > 1000 hours then true
